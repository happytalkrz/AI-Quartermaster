{
  "name": "ai-quartermaster",
  "version": "0.8.6",
  "description": "AI 병참부 - GitHub Issue to Draft PR automation pipeline",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/cli.js",
  "bin": {
    "aqm": "bin/aqm"
  },
  "files": [
    "bin/",
    "dist/",
    "prompts/",
    "docs/",
    "config.reference.yml",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "postbuild": "node scripts/add-shebang.cjs",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --project=visual-desktop --project=visual-mobile",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "smoke": "bash scripts/smoke-test.sh",
    "check:pack": "node scripts/check-package-integrity.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.4.3",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.12.8",
    "minimatch": "^9.0.9",
    "node-cron": "^3.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.57.0",
    "vitest": "^1.3.0"
  }
}
