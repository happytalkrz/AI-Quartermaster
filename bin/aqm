#!/usr/bin/env bash
AQM_HOME="${AQM_HOME:-$HOME/.ai-quartermaster}"
AQM_PID_FILE="$AQM_HOME/.aqm-server.pid"
AQM_LOG_FILE="$AQM_HOME/logs/server.log"

if [ ! -d "$AQM_HOME" ]; then
  echo "AI 병참부가 설치되어 있지 않습니다."
  echo "설치: curl -fsSL https://raw.githubusercontent.com/happytalkrz/AI-Quartermaster/main/install.sh | bash"
  exit 1
fi

# Check if daemon is running
is_running() {
  [ -f "$AQM_PID_FILE" ] && kill -0 "$(cat "$AQM_PID_FILE")" 2>/dev/null
}

case "${1:-}" in
  update)
    echo "AI 병참부 업데이트 중..."
    cd "$AQM_HOME"
    BEFORE=$(git rev-parse HEAD)
    git pull --quiet
    AFTER=$(git rev-parse HEAD)
    if [ "$BEFORE" = "$AFTER" ]; then
      echo "이미 최신 버전입니다."
    else
      npm install --silent 2>/dev/null
      # Update wrapper script
      if [ -f "$AQM_HOME/bin/aqm" ]; then
        cp "$AQM_HOME/bin/aqm" "$HOME/.local/bin/aqm"
        chmod +x "$HOME/.local/bin/aqm"
      fi
      echo "업데이트 완료!"
      git --no-pager log --oneline "$BEFORE".."$AFTER"
    fi
    exit 0
    ;;
  uninstall)
    # Stop daemon if running
    if is_running; then
      kill "$(cat "$AQM_PID_FILE")" 2>/dev/null
      rm -f "$AQM_PID_FILE"
    fi
    echo "AI 병참부를 삭제합니다..."
    rm -rf "$AQM_HOME"
    rm -f "$HOME/.local/bin/aqm"
    echo "삭제 완료."
    exit 0
    ;;
  version|--version|-v)
    cd "$AQM_HOME"
    VERSION=$(node -e "console.log(JSON.parse(require('fs').readFileSync('package.json','utf8')).version)" 2>/dev/null || echo "unknown")
    COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "AI 병참부 v${VERSION} (${COMMIT})"
    exit 0
    ;;
  start)
    # Check for --daemon flag
    DAEMON=false
    ARGS=()
    for arg in "${@:2}"; do
      if [ "$arg" = "--daemon" ] || [ "$arg" = "-d" ]; then
        DAEMON=true
      else
        ARGS+=("$arg")
      fi
    done

    if [ "$DAEMON" = true ]; then
      if is_running; then
        echo "서버가 이미 실행 중입니다. (PID: $(cat "$AQM_PID_FILE"))"
        echo "중지: aqm stop"
        exit 1
      fi

      mkdir -p "$AQM_HOME/logs"
      echo "서버를 백그라운드에서 시작합니다..."
      cd "$AQM_HOME"
      nohup npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" start "${ARGS[@]}" \
        >> "$AQM_LOG_FILE" 2>&1 &
      echo $! > "$AQM_PID_FILE"
      sleep 2

      if is_running; then
        echo "서버 시작됨 (PID: $(cat "$AQM_PID_FILE"))"
        echo "로그: tail -f $AQM_LOG_FILE"
        echo "대시보드: http://localhost:${ARGS[1]:-3000}/"
        echo "중지: aqm stop"
      else
        echo "서버 시작 실패. 로그를 확인하세요:"
        tail -5 "$AQM_LOG_FILE"
        rm -f "$AQM_PID_FILE"
        exit 1
      fi
      exit 0
    fi

    # Foreground mode — pass through
    cd "$AQM_HOME"
    exec npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" start "${ARGS[@]}"
    ;;
  stop)
    if is_running; then
      PID=$(cat "$AQM_PID_FILE")
      echo "서버 중지 중... (PID: $PID)"
      kill "$PID" 2>/dev/null
      # Wait for graceful shutdown
      for i in $(seq 1 10); do
        if ! kill -0 "$PID" 2>/dev/null; then
          break
        fi
        sleep 1
      done
      # Force kill if still running
      if kill -0 "$PID" 2>/dev/null; then
        kill -9 "$PID" 2>/dev/null
      fi
      rm -f "$AQM_PID_FILE"
      echo "서버 중지 완료."
    else
      echo "실행 중인 서버가 없습니다."
      rm -f "$AQM_PID_FILE"
    fi
    exit 0
    ;;
  restart)
    "$0" stop
    sleep 1
    "$0" start --daemon "${@:2}"
    exit 0
    ;;
  logs)
    if [ -f "$AQM_LOG_FILE" ]; then
      tail -f "$AQM_LOG_FILE"
    else
      echo "로그 파일이 없습니다."
    fi
    exit 0
    ;;
esac

# Forward other commands to CLI
exec npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" "$@"
