#!/usr/bin/env bash
AQM_HOME="${AQM_HOME:-$HOME/.ai-quartermaster}"
AQM_PID_FILE="$AQM_HOME/.aqm-server.pid"
AQM_LOG_FILE="$AQM_HOME/logs/server.log"

if [ ! -d "$AQM_HOME" ]; then
  echo "AI Quartermaster가 설치되어 있지 않습니다."
  echo "설치: curl -fsSL https://raw.githubusercontent.com/happytalkrz/AI-Quartermaster/main/install.sh | bash"
  exit 1
fi

# Check if server is running (PID file + port-based detection)
is_server_running() {
  local port="${1:-3000}"

  # Check PID file first
  if [ -f "$AQM_PID_FILE" ]; then
    local pid=$(cat "$AQM_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi

  # Check port occupation as fallback
  local pid=$(lsof -ti :$port 2>/dev/null | head -n1)
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    return 0
  fi

  return 1
}

# Find server PID using PID file first, then port-based fallback
find_server_pid() {
  local port="${1:-3000}"

  # First try PID file
  if [ -f "$AQM_PID_FILE" ]; then
    local pid=$(cat "$AQM_PID_FILE")
    if kill -0 "$pid" 2>/dev/null; then
      echo "$pid"
      return 0
    fi
  fi

  # Fallback: find process by port using lsof
  local pid=$(lsof -ti :$port 2>/dev/null | head -n1)
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    echo "$pid"
    return 0
  fi

  return 1
}

case "${1:-}" in
  update)
    BRANCH="main"
    CLEAN_FLAG=false

    while [ $# -gt 1 ]; do
      shift
      case "$1" in
        --branch)
          BRANCH="${2:-main}"
          shift
          ;;
        --clean)
          CLEAN_FLAG=true
          ;;
        --*)
          echo "Unknown option: $1"
          exit 1
          ;;
        *)
          BRANCH="$1"
          ;;
      esac
    done

    echo "AI Quartermaster 업데이트 중... (브랜치: $BRANCH)"
    cd "$AQM_HOME"
    BEFORE=$(git rev-parse HEAD)
    git fetch --quiet origin
    git checkout --quiet "$BRANCH"
    git pull --quiet origin "$BRANCH"
    AFTER=$(git rev-parse HEAD)

    # Handle --clean option
    if [ "$CLEAN_FLAG" = true ]; then
      echo "untracked 파일 정리 확인 중..."
      CLEAN_OUTPUT=$(git clean -fd --dry-run)
      if [ -n "$CLEAN_OUTPUT" ]; then
        echo "다음 untracked 파일/디렉토리가 삭제됩니다:"
        echo "$CLEAN_OUTPUT"
        git clean -fd
        echo "untracked 파일 정리 완료."
      else
        echo "정리할 untracked 파일이 없습니다."
      fi
    fi

    if [ "$BEFORE" = "$AFTER" ]; then
      echo "이미 최신 버전입니다."
    else
      npm install --silent 2>/dev/null
      # Update wrapper script
      if [ -f "$AQM_HOME/bin/aqm" ]; then
        cp "$AQM_HOME/bin/aqm" "$HOME/.local/bin/aqm"
        chmod +x "$HOME/.local/bin/aqm"
      fi
      echo "업데이트 완료!"
      git --no-pager log --oneline "$BEFORE".."$AFTER"
    fi
    exit 0
    ;;
  uninstall)
    # Stop daemon if running
    if is_server_running; then
      kill "$(cat "$AQM_PID_FILE")" 2>/dev/null
      rm -f "$AQM_PID_FILE"
    fi
    echo "AI Quartermaster를 삭제합니다..."
    rm -rf "$AQM_HOME"
    rm -f "$HOME/.local/bin/aqm"
    echo "삭제 완료."
    exit 0
    ;;
  version|--version|-v)
    cd "$AQM_HOME"
    VERSION=$(node -e "console.log(JSON.parse(require('fs').readFileSync('package.json','utf8')).version)" 2>/dev/null || echo "unknown")
    COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    echo "AI Quartermaster v${VERSION} (${COMMIT})"
    exit 0
    ;;
  start)
    # Check for --daemon flag
    DAEMON=false
    ARGS=()
    for arg in "${@:2}"; do
      if [ "$arg" = "--daemon" ] || [ "$arg" = "-d" ]; then
        DAEMON=true
      else
        ARGS+=("$arg")
      fi
    done

    if [ "$DAEMON" = true ]; then
      # Extract --port flag, default to 3000
      PORT=3000
      for ((i=0; i<${#ARGS[@]}; i++)); do
        if [ "${ARGS[i]}" = "--port" ] && [ $((i+1)) -lt ${#ARGS[@]} ]; then
          PORT="${ARGS[i+1]}"
          break
        fi
      done

      if is_server_running "$PORT"; then
        # Find the actual running PID
        RUNNING_PID=$(find_server_pid "$PORT")
        if [ -n "$RUNNING_PID" ]; then
          echo "서버가 이미 실행 중입니다. (PID: $RUNNING_PID, Port: $PORT)"
        else
          echo "서버가 이미 실행 중입니다. (Port: $PORT)"
        fi
        echo "중지: aqm stop"
        exit 1
      fi

      mkdir -p "$AQM_HOME/logs"
      echo "서버를 백그라운드에서 시작합니다..."
      cd "$AQM_HOME"
      nohup npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" start "${ARGS[@]}" \
        >> "$AQM_LOG_FILE" 2>&1 &
      echo $! > "$AQM_PID_FILE"
      sleep 2

      if is_server_running "$PORT"; then
        echo "서버 시작됨 (PID: $(cat "$AQM_PID_FILE"))"
        echo "로그: tail -f $AQM_LOG_FILE"
        echo "대시보드: http://localhost:${PORT}/"
        echo "중지: aqm stop"
      else
        echo "서버 시작 실패. 로그를 확인하세요:"
        tail -5 "$AQM_LOG_FILE"
        rm -f "$AQM_PID_FILE"
        exit 1
      fi
      exit 0
    fi

    # Foreground mode — pass through
    cd "$AQM_HOME"
    exec npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" start "${ARGS[@]}"
    ;;
  stop)
    # Extract port from config or use default
    PORT=3000
    if [ -f "$AQM_HOME/config.yml" ]; then
      PORT=$(grep -E "^\s*port\s*:" "$AQM_HOME/config.yml" 2>/dev/null | sed -E 's/^\s*port\s*:\s*([0-9]+).*/\1/' | head -n1)
      if [ -z "$PORT" ] || [ "$PORT" -eq 0 ] 2>/dev/null; then
        PORT=3000
      fi
    fi

    # Find server PID using fallback logic
    PID=$(find_server_pid "$PORT")
    if [ $? -eq 0 ] && [ -n "$PID" ]; then
      echo "서버 중지 중... (PID: $PID, Port: $PORT)"
      kill "$PID" 2>/dev/null
      # Wait for graceful shutdown
      for i in $(seq 1 10); do
        if ! kill -0 "$PID" 2>/dev/null; then
          break
        fi
        sleep 1
      done
      # Force kill if still running
      if kill -0 "$PID" 2>/dev/null; then
        echo "강제 종료 시도 중..."
        kill -9 "$PID" 2>/dev/null
      fi
      rm -f "$AQM_PID_FILE"
      echo "서버 중지 완료."
    else
      echo "실행 중인 서버가 없습니다."
      rm -f "$AQM_PID_FILE"
    fi
    exit 0
    ;;
  restart)
    "$0" stop
    sleep 1
    "$0" start --daemon "${@:2}"
    exit 0
    ;;
  logs)
    if [ -f "$AQM_LOG_FILE" ]; then
      tail -f "$AQM_LOG_FILE"
    else
      echo "로그 파일이 없습니다."
    fi
    exit 0
    ;;
esac

# Forward other commands to CLI
cd "$AQM_HOME"
exec npx --prefix "$AQM_HOME" tsx "$AQM_HOME/src/cli.ts" "$@"
